@model IEnumerable<AurumFinance.Models.ChartOfAccount>
@{
    ViewData["Title"] = "Chart of Accounts";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-diagram-3 me-2 text-warning"></i> Chart of Accounts</h2>
            <p class="text-muted mb-0">Master list of financial accounts (Automatically sorted by reference).</p>
        </div>
        <div>
            <button class="btn btn-warning fw-semibold" data-bs-toggle="modal" data-bs-target="#addAccountModal">
                <i class="bi bi-plus-lg me-1"></i> New Account
            </button>
        </div>
    </div>

    <!-- Alert Notifications -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-danger bg-dark text-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-success bg-dark text-success" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- COA Table Card -->
    <div class="card bg-dark border-secondary text-white shadow-sm">
        <div class="card-header bg-transparent border-secondary py-3 d-flex justify-content-between align-items-center">
            <div class="d-flex gap-2">
                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="Search accounts..." style="width: 250px;">
                <select class="form-select form-select-sm bg-dark text-white border-secondary" style="width: 180px;">
                    <option value="">All Categories</option>
                    <option value="Assets">Assets</option>
                    <option value="Liabilities">Liabilities</option>
                    <option value="Equity">Equity</option>
                    <option value="OperatingIncome">Operating Income</option>
                    <option value="OperatingExpenses">Operating Expenses</option>
                    <option value="OtherIncome">Other Income</option>
                    <option value="OtherExpenses">Other Expenses</option>
                </select>
            </div>
            <span class="text-muted small">Total Accounts: @Model.Count()</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead class="table-active border-bottom border-secondary">
                        <tr>
                            <th style="width: 120px;">Ref No.</th>
                            <th>Account Name</th>
                            <th>Category</th>
                            <th>Role</th>
                            <th class="text-end">Current Balance</th>
                            <th class="text-center" style="width: 100px;">Status</th>
                            <th class="text-center" style="width: 130px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(Model.Any())
                        {
                            foreach (var account in Model)
                            {
                                <tr>
                                    <td><code>@account.ReferenceNumber</code></td>
                                    <td class="fw-bold">@account.AccountName</td>
                                    <td>
                                        <span class="badge bg-secondary bg-opacity-25 text-light border border-secondary">
                                            @account.Type
                                        </span>
                                    </td>
                                    <td>
                                        @if(account.Role != "Default")
                                        {
                                            <span class="badge bg-info text-dark">@account.Role</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Standard</span>
                                        }
                                    </td>
                                    <td class="text-end fw-semibold @(account.Balance >= 0 ? "text-success" : "text-danger")">
                                        @account.Balance.ToString("C")
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(account.IsActive ? "bg-success" : "bg-danger")">
                                            @(account.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <button class="btn btn-sm btn-outline-light" title="Edit Account">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <a href="@Url.Action("ViewLedger", "Ledger", new { accountId = account.Id })" class="btn btn-sm btn-outline-info" title="View General Ledger">
                                                <i class="bi bi-journal-text"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">No accounts found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Add Account -->
<div class="modal fade" id="addAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary text-white">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-warning"><i class="bi bi-plus-circle me-1"></i> Add New Account</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-controller="Accounts" asp-action="Create">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Account Category</label>
                        <select id="accountType" name="Type" class="form-select bg-dark text-white border-secondary" required onchange="enforceNumberingRule()">
                            <option value="">-- Select Category --</option>
                            <option value="Assets">Assets (100 - 199)</option>
                            <option value="Liabilities">Liabilities (200 - 299)</option>
                            <option value="Equity">Equity (300 - 399)</option>
                            <option value="OperatingIncome">Operating Income (400 - 499)</option>
                            <option value="OperatingExpenses">Operating Expenses (500 - 599)</option>
                            <option value="OtherIncome">Other Income (600 - 799)</option>
                            <option value="OtherExpenses">Other Expenses (800 - 999)</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Reference Number (Account Code)</label>
                        <input type="number" id="referenceNumber" name="ReferenceNumber" class="form-control bg-dark text-white border-secondary" placeholder="Select category first..." required disabled />
                        <div id="refHelpText" class="form-text text-info">Please select an account category to see the valid numbering range.</div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Account Name</label>
                        <input type="text" name="AccountName" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Rent Expense" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">System Role (Special Calculations)</label>
                        <select name="Role" class="form-select bg-dark text-white border-secondary" required>
                            <option value="Default">Standard / Default</option>
                            <option value="CashAndEquivalents">Cash & Equivalents</option>
                            <option value="RetainedEarnings">Retained Earnings</option>
                            <option value="TaxPayable">Tax Payable</option>
                            <option value="CostOfGoodsSold">Cost of Goods Sold (COGS)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning fw-semibold">Save Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function enforceNumberingRule() {
            const typeSelect = document.getElementById('accountType');
            const refInput = document.getElementById('referenceNumber');
            const helpText = document.getElementById('refHelpText');

            const rules = {
                'Assets': { min: 100, max: 199 },
                'Liabilities': { min: 200, max: 299 },
                'Equity': { min: 300, max: 399 },
                'OperatingIncome': { min: 400, max: 499 },
                'OperatingExpenses': { min: 500, max: 599 },
                'OtherIncome': { min: 600, max: 799 },
                'OtherExpenses': { min: 800, max: 999 }
            };

            const selectedValue = typeSelect.value;

            if (selectedValue && rules[selectedValue]) {
                const rule = rules[selectedValue];
                
                refInput.disabled = false;
                refInput.min = rule.min;
                refInput.max = rule.max;
                refInput.placeholder = `Enter a number between ${rule.min} and ${rule.max}`;
                
                helpText.innerHTML = `Valid range for this category: <strong>${rule.min} - ${rule.max}</strong>.`;
                helpText.className = "form-text text-warning";
                
                if(refInput.value && (refInput.value < rule.min || refInput.value > rule.max)) {
                    refInput.value = '';
                }
            } else {
                refInput.disabled = true;
                refInput.value = '';
                refInput.placeholder = "Select category first...";
                helpText.textContent = "Please select an account category to see the valid numbering range.";
                helpText.className = "form-text text-info";
            }
        }
    </script>
}