@model AurumFinance.Models.ResetPasswordModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow-lg" style="width: 100%; max-width: 420px;">
        <h3 class="mb-3 text-center fw-bold">Reset Password</h3>
        <p class="text-muted text-center mb-4">Choose a new password for your account</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger p-2" role="alert">
                <div asp-validation-summary="All" class="small mb-0"></div>
            </div>
        }

        <form method="post" asp-controller="Auth" asp-action="ResetPassword">
            @Html.AntiForgeryToken()
            <input asp-for="Token" type="hidden" />

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" required />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" required />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-2">Reset Password</button>
        </form>

        <p class="text-center small mt-3 mb-0">
            <a asp-controller="Auth" asp-action="Login">Back to login</a>
        </p>
    </div>
</div>
