@model AurumFinance.Models.ResendVerificationModel

@{
    ViewData["Title"] = "Resend Verification Email";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow-lg" style="width: 100%; max-width: 420px;">
        <h3 class="mb-3 text-center fw-bold">Resend Verification Email</h3>
        <p class="text-muted text-center mb-4">Enter your email and we'll send a new verification link</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger p-2" role="alert">
                <div asp-validation-summary="All" class="small mb-0"></div>
            </div>
        }

        <form method="post" asp-controller="Auth" asp-action="ResendVerification">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" required />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-2">Send Verification Link</button>
        </form>

        <p class="text-center small mt-3 mb-0">
            <a asp-controller="Auth" asp-action="Login">Back to login</a>
        </p>
    </div>
</div>
