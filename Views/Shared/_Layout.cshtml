<!DOCTYPE html>
<html lang="en-US" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aurum Finance</title>
    
    <!-- CSS Dependencies -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    
    <!-- Instant Theme Loader (Prevents Screen Flicker) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('aurum_theme') || 'dark';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
        })();
    </script>

    <style>
        /* Smooth theme transition */
        body {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Sidebar Base Styling */
        .sidebar { 
            transition: width 0.3s ease, padding 0.3s ease; 
            overflow: hidden; 
            background-color: #181818; 
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            flex-shrink: 0;
        }
        
        /* Sidebar Width Settings */
        .sidebar.expanded { 
            width: 220px; 
        }
        
        .sidebar.collapsed { 
            width: 68px; 
            padding-left: 0.75rem !important;
            padding-right: 0.75rem !important;
        }

        /* Keep sidebar dark & sleek even in Light Mode */
        [data-bs-theme="light"] .sidebar {
            background-color: #212529 !important; 
        }

        /* Hide text elements when sidebar is collapsed */
        .sidebar.collapsed .menu-text,
        .sidebar.collapsed .brand-header-text,
        .sidebar.collapsed .version-text,
        .sidebar.collapsed .settings-icon {
            display: none !important;
        }

        /* Center icons and alignment in collapsed mode */
        .sidebar.collapsed .brand-container {
            justify-content: center !important;
            width: 100%;
        }

        .sidebar.collapsed .nav-link {
            display: flex;
            justify-content: center;
            align-items: center;
            padding-left: 0;
            padding-right: 0;
        }

        .sidebar.collapsed .nav-link i,
        .sidebar.collapsed .border-top i {
            margin-right: 0 !important;
        }

        .sidebar.collapsed .mt-auto .d-flex {
            justify-content: center;
        }

        /* 
           =========================================================
           PENGATURAN FONT TULISAN "AURUM FINANCE"
           =========================================================
        */
        .brand-header { 
            font-weight: bold; 
            font-size: 1.25rem; /* <--- UBAH UKURAN FONT DI SINI (contoh: 1.5rem, 18px, dll) */
            color: #ffffff;
        }

        .version-text { 
            font-size: 0.75rem; /* <--- UBAH UKURAN FONT VERSI (v10.0.0) DI SINI */
            opacity: 0.6; 
        }

        /* Navigation Links */
        .nav-link { 
            white-space: nowrap; 
            color: #b0b0b0 !important; 
            border-radius: 0.375rem;
        }
        .nav-link:hover, .nav-link.active { 
            background-color: rgba(255, 255, 255, 0.1) !important; 
            color: #ffffff !important;
        }

        /* Main Content Container */
        .content { 
            transition: background-color 0.3s ease;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex vh-100">
        <!-- Sidebar Partial View -->
        <partial name="_Sidebar" />

        <!-- Main Content Area -->
        <main id="mainContent" class="content flex-grow-1 p-4 overflow-auto" role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Scripts -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Sidebar Toggle Logic
            const sidebar = document.getElementById('sidebar');
            const toggleBtn = document.getElementById('toggleSidebar');

            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener('click', () => {
                    sidebar.classList.toggle('expanded');
                    sidebar.classList.toggle('collapsed');
                });
            }

            // Global Theme Switcher Function
            window.setAppTheme = function(themeName) {
                document.documentElement.setAttribute('data-bs-theme', themeName);
                localStorage.setItem('aurum_theme', themeName);
            };
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>