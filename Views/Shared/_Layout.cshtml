<!DOCTYPE html>
<html lang="en-US" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aurum Finance</title>
    
    <!-- CSS Dependencies -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    
    <!-- Instant Theme Loader -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('aurum_theme') || 'dark';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
        })();
    </script>

    <style>
        body {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Sidebar Statis Murni (Kunci di 70px) */
        .sidebar { 
            width: 70px; 
            min-height: 100vh;
            background-color: #181818; 
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            flex-shrink: 0;
        }

        .sidebar .icon-btn {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.5rem;
            color: #b0b0b0 !important;
            transition: all 0.2s ease;
        }

        .sidebar .icon-btn:hover, 
        .sidebar .icon-btn.active { 
            background-color: rgba(255, 255, 255, 0.15) !important; 
            color: #ffffff !important;
        }

        /* Light Mode Adjustment */
        [data-bs-theme="light"] .sidebar {
            background-color: #212529 !important; 
        }

        .content { 
            transition: background-color 0.3s ease;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex vh-100">
        <!-- Sidebar Partial View -->
        <partial name="_Sidebar" />

        <!-- Main Content Area -->
        <main id="mainContent" class="content flex-grow-1 p-4 overflow-auto" role="main">
            @RenderBody()
        </main>
    </div>

    <!-- JS Dependencies (Memastikan Bootstrap Bundle Terpasang untuk Dropdown User) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            window.setAppTheme = function(themeName) {
                document.documentElement.setAttribute('data-bs-theme', themeName);
                localStorage.setItem('aurum_theme', themeName);
            };
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>