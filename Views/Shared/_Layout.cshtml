<!DOCTYPE html>
<html lang="en-US" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aurum Finance</title>
    
    <!-- CSS Dependencies -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    
    <!-- Instant Theme Loader -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('aurum_theme') || 'dark';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
        })();
    </script>

    <style>
        body {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .sidebar-wrapper {
            position: relative;
            z-index: 100;
        }

        /* Static Icon Bar (52px) */
        .sidebar-icons { 
            width: 52px; 
            min-height: 100vh;
            background-color: #181818; 
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            flex-shrink: 0;
            z-index: 2;
        }

        .sidebar-icons .icon-btn {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.375rem;
            color: #b0b0b0 !important;
            transition: all 0.2s ease;
        }

        .sidebar-icons .icon-btn:hover, 
        .sidebar-icons .icon-btn.active { 
            background-color: rgba(255, 255, 255, 0.15) !important; 
            color: #ffffff !important;
        }

        /* Compact Flyout Panel */
        .sidebar-flyout {
            width: 0;
            opacity: 0;
            visibility: hidden;
            overflow: hidden;
            min-height: 100vh;
            background-color: #212529 !important;
            transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease;
            white-space: nowrap;
            z-index: 1;
        }

        .sidebar-flyout.show {
            width: 190px;
            opacity: 1;
            visibility: visible;
        }

        .sidebar-flyout .list-group-item {
            font-size: 0.85rem;
        }

        .sidebar-flyout .list-group-item:hover {
            background-color: rgba(255, 255, 255, 0.1) !important;
        }

        [data-bs-theme="light"] .sidebar-icons {
            background-color: #1e2227 !important; 
        }

        .content { 
            transition: background-color 0.3s ease;
        }

        .fs-7 { font-size: 0.825rem; }
        .fs-8 { font-size: 0.725rem; }

        /* MENGUNCI TEKS TERJEMAH MAKSIMAL 3 BARIS */
        .quran-clamp {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.35;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex vh-100 overflow-hidden">
        <!-- Sidebar Partial View -->
        <partial name="_Sidebar" />

        <!-- Area Kanan Utama -->
        <div class="d-flex flex-column flex-grow-1 min-vw-0">
            
            <!-- TopBar Partial View -->
            <partial name="_TopBar" />

            <!-- Main Content Area -->
            <main id="mainContent" class="content flex-grow-1 p-4 overflow-auto" role="main">
                @RenderBody()
            </main>

        </div>
    </div>

    <!-- JS Dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Sidebar & Theme Toggle Script -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const btnReports = document.getElementById('btn-toggle-reports');
            const btnCloseReports = document.getElementById('btn-close-reports');
            const flyoutPanel = document.getElementById('reports-flyout');

            if (btnReports && flyoutPanel) {
                btnReports.addEventListener('click', function (e) {
                    e.stopPropagation();
                    btnReports.classList.toggle('active');
                    flyoutPanel.classList.toggle('show');
                });

                if (btnCloseReports) {
                    btnCloseReports.addEventListener('click', function () {
                        btnReports.classList.remove('active');
                        flyoutPanel.classList.remove('show');
                    });
                }
            }

            window.setAppTheme = function(themeName) {
                document.documentElement.setAttribute('data-bs-theme', themeName);
                localStorage.setItem('aurum_theme', themeName);
            };
        });
    </script>

    <!-- LOGIK ROTASI AL-QUR'AN 17X SEHARI (US ENGLISH) -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Daftar 17 Potongan Ayat Pilihan (Terjemahan Saheeh International / US English)
            const verses = [
                { text: `"Guide us to the straight path - The path of those upon whom You have bestowed favor, not of those who have evoked [Your] anger or of those who are astray."`, ref: "QS. Al-Fatihah 1:6-7" },
                { text: `"O you who have believed, seek help through patience and prayer. Indeed, Allah is with the patient."`, ref: "QS. Al-Baqarah 2:153" },
                { text: `"Allah does not charge a soul except with that which He has given it. Allah will bring about ease after hardship."`, ref: "QS. At-Talaq 65:7" },
                { text: `"And whoever fears Allah - He will make for him a way out, and will provide for him from where he does not expect."`, ref: "QS. At-Talaq 65:2-3" },
                { text: `"And fulfill every commitment. Indeed, the commitment will be inquired into."`, ref: "QS. Al-Isra 17:34" },
                { text: `"So remember Me; I will remember you. And be grateful to Me and do not deny Me."`, ref: "QS. Al-Baqarah 2:152" },
                { text: `"Unquestionably, by the remembrance of Allah do hearts find rest."`, ref: "QS. Ar-Ra'd 13:28" },
                { text: `"For indeed, with hardship [will be] ease. Indeed, with hardship [will be] ease."`, ref: "QS. Ash-Sharh 94:5-6" },
                { text: `"And give full measure when you measure, and weigh with an even balance. That is the best way and best in result."`, ref: "QS. Al-Isra 17:35" },
                { text: `"O you who have believed, fear Allah and speak words of worldly accuracy and justice."`, ref: "QS. Al-Ahzab 33:70" },
                { text: `"And do not consume one another's wealth unjustly or send it [in bribes] to the rulers in order that [they might] aid you to consume a portion of the wealth of the people in sin while you know [it is unlawful]."`, ref: "QS. Al-Baqarah 2:188" },
                { text: `"Sufficient for us is Allah, and [He is] the best Disposer of affairs."`, ref: "QS. Ali 'Imran 3:173" },
                { text: `"Call upon Me; I will respond to you."`, ref: "QS. Ghafir 40:60" },
                { text: `"And rely upon Allah ; and sufficient is Allah as Disposer of affairs."`, ref: "QS. Al-Ahzab 33:3" },
                { text: `"O you who have believed, be persistently standing firm in justice, witnesses for Allah, even if it be against yourselves or parents and relatives."`, ref: "QS. An-Nisa 4:135" },
                { text: `"Say, 'O My servants who have transgressed against themselves [by sinning], do not despair of the mercy of Allah. Indeed, Allah forgives all sins. Indeed, it is He who is the Forgiving, the Merciful.'"`, ref: "QS. Az-Zumar 39:53" },
                { text: `"And say, 'My Lord, increase me in knowledge.'"`, ref: "QS. Taha 20:114" }
            ];

            function updateQuranVerse() {
                const now = new Date();
                const totalMinutes = (now.getHours() * 60) + now.getMinutes();
                
                // Membagi 1440 menit (1 hari) menjadi 17 interval (~84.7 menit sekali ganti)
                const intervalMinutes = 1440 / 17;
                const slotIndex = Math.floor(totalMinutes / intervalMinutes) % 17;

                const selectedVerse = verses[slotIndex];
                
                const textElem = document.getElementById('quranVerseText');
                const refElem = document.getElementById('quranVerseRef');

                if (textElem && refElem) {
                    textElem.textContent = selectedVerse.text;
                    refElem.textContent = selectedVerse.ref;
                }
            }

            // Jalankan saat load
            updateQuranVerse();

            // Cek setiap 1 menit untuk update jika slot interval berganti
            setInterval(updateQuranVerse, 60000);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<!-- JS Dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
<!-- Custom Script Quran Banner -->
    <script src="~/js/quran-banner.js" asp-append-version="true"></script>