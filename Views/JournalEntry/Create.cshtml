@{
    ViewData["Title"] = "Create Journal Entry";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-journal-plus me-2 text-warning"></i> Create Journal Entry</h2>
            <p class="text-muted mb-0">Record double-entry financial transactions or adjusting entries for Aurum Finance.</p>
        </div>
        <div>
            <a asp-controller="GeneralJournal" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Journal
            </a>
        </div>
    </div>

    <form id="journalForm" method="post">
        <!-- Transaction Header Metadata -->
        <div class="card bg-dark border-secondary text-white shadow-sm mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <!-- Journal Type Picker -->
                    <div class="col-md-3">
                        <label class="form-label fw-semibold text-warning">Journal Type</label>
                        <select class="form-select bg-dark text-white border-secondary fw-semibold" id="journalType">
                            <option value="General" selected>General Journal (GJ)</option>
                            <option value="Adjusting">Adjusting Entry (AJE)</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Transaction Date</label>
                        <input type="date" class="form-control bg-dark text-white border-secondary" required value="2026-07-22" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Reference / Voucher No.</label>
                        <input type="text" id="refNumber" class="form-control bg-dark text-white border-secondary" value="GJ-2026-003" required />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">General Description / Memo</label>
                        <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Brief summary of entry..." />
                    </div>
                </div>
            </div>
        </div>

        <!-- Journal Lines Table -->
        <div class="card bg-dark border-secondary text-white shadow-sm mb-4">
            <div class="card-header bg-transparent border-secondary d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0 text-warning"><i class="bi bi-list-task me-2"></i> Journal Lines</h5>
                <button type="button" class="btn btn-sm btn-outline-warning" id="btnAddRow">
                    <i class="bi bi-plus-lg me-1"></i> Add Line
                </button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark align-middle mb-0" id="journalTable">
                        <thead class="table-active border-bottom border-secondary">
                            <tr>
                                <th style="width: 30%;">Account</th>
                                <th style="width: 30%;">Line Description</th>
                                <th style="width: 17%;" class="text-end">Debit ($)</th>
                                <th style="width: 17%;" class="text-end">Credit ($)</th>
                                <th style="width: 6%;" class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="journalBody">
                            <!-- Line 1 -->
                            <tr>
                                <td>
                                    <select class="form-select bg-dark text-white border-secondary" required>
                                        <option value="" selected disabled>Select Account...</option>
                                        <option value="101">101 - Cash</option>
                                        <option value="102">102 - Accounts Receivable</option>
                                        <option value="301">301 - Owner's Equity</option>
                                        <option value="501">501 - Rent Expense</option>
                                        <option value="502">502 - Depreciation Expense</option>
                                        <option value="105">105 - Accumulated Depreciation</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Note..." />
                                </td>
                                <td>
                                    <input type="number" step="0.01" min="0" class="form-control bg-dark text-white border-secondary text-end input-debit" placeholder="0.00" />
                                </td>
                                <td>
                                    <input type="number" step="0.01" min="0" class="form-control bg-dark text-white border-secondary text-end input-credit" placeholder="0.00" />
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-remove"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                            <!-- Line 2 -->
                            <tr>
                                <td>
                                    <select class="form-select bg-dark text-white border-secondary" required>
                                        <option value="" selected disabled>Select Account...</option>
                                        <option value="101">101 - Cash</option>
                                        <option value="102">102 - Accounts Receivable</option>
                                        <option value="301">301 - Owner's Equity</option>
                                        <option value="501">501 - Rent Expense</option>
                                        <option value="502">502 - Depreciation Expense</option>
                                        <option value="105">105 - Accumulated Depreciation</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Note..." />
                                </td>
                                <td>
                                    <input type="number" step="0.01" min="0" class="form-control bg-dark text-white border-secondary text-end input-debit" placeholder="0.00" />
                                </td>
                                <td>
                                    <input type="number" step="0.01" min="0" class="form-control bg-dark text-white border-secondary text-end input-credit" placeholder="0.00" />
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-remove"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot class="table-active border-top border-secondary fw-bold">
                            <tr>
                                <td colspan="2" class="text-end">Total:</td>
                                <td class="text-end text-success fs-6" id="totalDebit">$0.00</td>
                                <td class="text-end text-danger fs-6" id="totalCredit">$0.00</td>
                                <td></td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-end">Status:</td>
                                <td colspan="2" class="text-center" id="balanceStatus">
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Balanced</span>
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Form Action Controls -->
        <div class="d-flex justify-content-end gap-2">
            <button type="reset" class="btn btn-outline-light px-4">Reset</button>
            <button type="submit" class="btn btn-warning fw-semibold px-4" id="btnSubmit">
                <i class="bi bi-save me-1"></i> Post Journal Entry
            </button>
        </div>
    </form>
</div>

<!-- Interactive Dynamic Logic -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const journalBody = document.getElementById("journalBody");
        const btnAddRow = document.getElementById("btnAddRow");
        const totalDebitEl = document.getElementById("totalDebit");
        const totalCreditEl = document.getElementById("totalCredit");
        const balanceStatusEl = document.getElementById("balanceStatus");
        const btnSubmit = document.getElementById("btnSubmit");
        const journalTypeEl = document.getElementById("journalType");
        const refNumberEl = document.getElementById("refNumber");

        // Ganti Prefix Referensi berdasarkan Tipe Jurnal
        journalTypeEl.addEventListener("change", function () {
            if (this.value === "Adjusting") {
                refNumberEl.value = "AJE-2026-001";
            } else {
                refNumberEl.value = "GJ-2026-003";
            }
        });

        function createRowHtml() {
            return `
                <tr>
                    <td>
                        <select class="form-select bg-dark text-white border-secondary" required>
                            <option value="" selected disabled>Select Account...</option>
                            <option value="101">101 - Cash</option>
                            <option value="102">102 - Accounts Receivable</option>
                            <option value="301">301 - Owner's Equity</option>
                            <option value="501">501 - Rent Expense</option>
                            <option value="502">502 - Depreciation Expense</option>
                            <option value="105">105 - Accumulated Depreciation</option>
                        </select>
                    </td>
                    <td>
                        <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Note..." />
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" class="form-control bg-dark text-white border-secondary text-end input-debit" placeholder="0.00" />
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" class="form-control bg-dark text-white border-secondary text-end input-credit" placeholder="0.00" />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger btn-remove"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
            `;
        }

        function calculateTotals() {
            let totalDebit = 0;
            let totalCredit = 0;

            document.querySelectorAll(".input-debit").forEach(input => {
                totalDebit += parseFloat(input.value) || 0;
            });

            document.querySelectorAll(".input-credit").forEach(input => {
                totalCredit += parseFloat(input.value) || 0;
            });

            totalDebitEl.textContent = `$${totalDebit.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
            totalCreditEl.textContent = `$${totalCredit.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;

            const difference = Math.abs(totalDebit - totalCredit);

            if (totalDebit > 0 && totalCredit > 0 && difference < 0.001) {
                balanceStatusEl.innerHTML = `<span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Balanced</span>`;
                btnSubmit.disabled = false;
            } else {
                const diffFormatted = `$${difference.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
                balanceStatusEl.innerHTML = `<span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i> Unbalanced (${diffFormatted})</span>`;
                btnSubmit.disabled = true;
            }
        }

        btnAddRow.addEventListener("click", function () {
            journalBody.insertAdjacentHTML("beforeend", createRowHtml());
        });

        journalBody.addEventListener("click", function (e) {
            if (e.target.closest(".btn-remove")) {
                if (journalBody.querySelectorAll("tr").length > 2) {
                    e.target.closest("tr").remove();
                    calculateTotals();
                } else {
                    alert("A journal entry must have at least two line items (Debit & Credit).");
                }
            }
        });

        journalBody.addEventListener("input", function (e) {
            if (e.target.classList.contains("input-debit") || e.target.classList.contains("input-credit")) {
                calculateTotals();
            }
        });

        calculateTotals();
    });
</script>