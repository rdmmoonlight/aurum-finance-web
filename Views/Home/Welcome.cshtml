@{
    ViewData["Title"] = "Welcome";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <div class="card border-0 shadow-sm rounded-4 bg-body-tertiary text-center p-5">
                <!-- Success Icon -->
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                </div>
                
                <!-- Dynamic Message from Controller -->
                <h2 class="fw-bold text-body-emphasis mb-3">
                    @(ViewData["Message"] ?? "Authentication Successful")
                </h2>
                
                <p class="text-secondary mb-4">
                    You have securely accessed your Aurum Finance account. Your financial workspace and general ledgers are ready.
                </p>
                
                <!-- Action Buttons -->
                <div class="d-flex flex-wrap justify-content-center gap-3 mt-2">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-warning px-4 fw-semibold shadow-sm d-flex align-items-center gap-2">
                        <i class="bi bi-columns-gap"></i> Go to Dashboard
                    </a>
                    
                    <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger px-4 fw-semibold shadow-sm d-flex align-items-center gap-2">
                        <i class="bi bi-box-arrow-right"></i> Sign Out
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>