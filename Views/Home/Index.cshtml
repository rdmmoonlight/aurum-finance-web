@{
    ViewData["Title"] = "Home";
}

<div class="container py-5 mt-4">
    
    <!-- 1. Hero Section -->
    <div class="text-center mb-5">
        <div class="mb-4 text-warning">
            <!-- Main Application Icon -->
            <i class="bi bi-shield-lock-fill" style="font-size: 4.5rem;"></i>
        </div>
        <h1 class="display-5 fw-bold text-body-emphasis mb-3">^^</h1>
        <p class="lead text-secondary mb-4 mx-auto" style="max-width: 650px;">
            An integrated financial and accounting information system. Manage your full accounting cycle—from general journal entries to balance sheets—with precision, discipline, and absolute accuracy.
        </p>
        
        <!-- Call to Action Buttons -->
        <div class="d-flex justify-content-center gap-3 mt-4">
            <a asp-controller="Auth" asp-action="Login" class="btn btn-warning btn-lg px-4 fw-semibold shadow-sm d-flex align-items-center gap-2">
                <i class="bi bi-box-arrow-in-right"></i> Sign In
            </a>
            <a asp-controller="Auth" asp-action="Register" class="btn btn-outline-secondary btn-lg px-4 fw-semibold shadow-sm d-flex align-items-center gap-2">
                <i class="bi bi-person-plus"></i> Create Account
            </a>
        </div>
    </div>

    <hr class="my-5 text-secondary opacity-25" />

    <!-- 2. Core Value Proposition Section -->
    <div class="row g-4 text-center">
        <!-- Feature 1 -->
        <div class="col-12 col-md-4">
            <div class="card bg-body-tertiary border-0 h-100 shadow-sm p-4 rounded-4">
                <div class="card-body">
                    <i class="bi bi-journal-check text-success fs-1 mb-3"></i>
                    <h5 class="fw-bold text-body">Centralized Journaling</h5>
                    <p class="text-secondary small mb-0">Strict double-entry bookkeeping for accurate and disciplined transaction recording.</p>
                </div>
            </div>
        </div>
        
        <!-- Feature 2 -->
        <div class="col-12 col-md-4">
            <div class="card bg-body-tertiary border-0 h-100 shadow-sm p-4 rounded-4">
                <div class="card-body">
                    <i class="bi bi-diagram-3 text-info fs-1 mb-3"></i>
                    <h5 class="fw-bold text-body">Chart of Accounts</h5>
                    <p class="text-secondary small mb-0">A structured, hierarchical Chart of Accounts (CoA) fully compliant with financial reporting standards.</p>
                </div>
            </div>
        </div>
        
        <!-- Feature 3 -->
        <div class="col-12 col-md-4">
            <div class="card bg-body-tertiary border-0 h-100 shadow-sm p-4 rounded-4">
                <div class="card-body">
                    <i class="bi bi-bar-chart-line text-primary fs-1 mb-3"></i>
                    <h5 class="fw-bold text-body">Real-Time Reporting</h5>
                    <p class="text-secondary small mb-0">Monitor Balance Sheets, Income Statements, and Cash Flows instantly for rational economic decision-making.</p>
                </div>
            </div>
        </div>
    </div>

</div>