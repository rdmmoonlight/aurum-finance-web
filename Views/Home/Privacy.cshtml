@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-4 mt-2">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            
            <!-- Page Header -->
            <div class="text-center mb-5">
                <i class="bi bi-shield-check text-primary" style="font-size: 3rem;"></i>
                <h1 class="display-6 fw-bold text-body-emphasis mt-3">@ViewData["Title"]</h1>
                <p class="text-secondary">Last updated: July 2026</p>
            </div>

            <!-- Policy Content -->
            <div class="card border-0 shadow-sm rounded-4 bg-body-tertiary">
                <div class="card-body p-4 p-md-5">
                    
                    <h4 class="fw-bold mb-3 text-body">1. Information Collection</h4>
                    <p class="text-secondary mb-4" style="line-height: 1.7;">
                        Aurum Finance is committed to protecting your privacy and the integrity of your financial data. We collect personal and business information strictly necessary to provide our accounting services. This includes user credentials, transactional records, and custom Chart of Accounts (CoA) data entered into the system.
                    </p>

                    <h4 class="fw-bold mb-3 text-body">2. How We Use Your Data</h4>
                    <p class="text-secondary mb-4" style="line-height: 1.7;">
                        Your data is processed exclusively to facilitate your bookkeeping and financial reporting. We use your inputs to generate general ledgers, trial balances, and income statements. <strong>Aurum Finance does not sell, lease, or share your proprietary financial data with third-party advertisers or external entities.</strong>
                    </p>

                    <h4 class="fw-bold mb-3 text-body">3. Data Security & Integrity</h4>
                    <p class="text-secondary mb-4" style="line-height: 1.7;">
                        Recognizing the sensitive nature of financial records, our system employs industry-standard security measures. This includes secure authentication protocols, database encryption, and strict role-based access controls to prevent unauthorized access, alteration, or disclosure of your general journal entries.
                    </p>

                    <h4 class="fw-bold mb-3 text-body">4. User Rights & Data Ownership</h4>
                    <p class="text-secondary mb-4" style="line-height: 1.7;">
                        You retain full ownership of all financial data inputted into Aurum Finance. You reserve the right to review, update, export, or permanently delete your financial records from our active databases, subject to standard accounting retention regulations.
                    </p>

                    <hr class="my-4 text-secondary opacity-25" />
                    
                    <div class="text-center">
                        <p class="small text-secondary mb-0">
                            If you have any inquiries regarding this Privacy Policy or our data processing practices, please contact your system administrator.
                        </p>
                    </div>
                    
                </div>
            </div>
            
        </div>
    </div>
</div>