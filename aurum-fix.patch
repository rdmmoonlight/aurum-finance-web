diff --git a/gradlew b/gradlew
new file mode 100755
index 0000000..2a5dd72
--- /dev/null
+++ b/gradlew
@@ -0,0 +1,9 @@
+#!/bin/sh
+DIR="$(cd "$(dirname "$0")" >/dev/null && pwd)"
+CLASSPATH="$DIR/gradle/wrapper/gradle-wrapper.jar"
+if [ ! -f "$CLASSPATH" ]; then
+  echo "ERROR: $CLASSPATH tidak ditemukan." >&2
+  echo "Jalankan 'gradle wrapper --gradle-version 8.7' sekali secara lokal untuk generate jar ini, lalu commit." >&2
+  exit 1
+fi
+exec java -cp "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
diff --git a/gradlew.bat b/gradlew.bat
new file mode 100644
index 0000000..73c0ab9
--- /dev/null
+++ b/gradlew.bat
@@ -0,0 +1,10 @@
+@rem Gradle startup script for Windows
+@if "%DEBUG%"=="" @echo off
+set DIR=%~dp0
+set CLASSPATH=%DIR%gradle\wrapper\gradle-wrapper.jar
+if not exist "%CLASSPATH%" (
+  echo ERROR: %CLASSPATH% tidak ditemukan.
+  echo Jalankan "gradle wrapper --gradle-version 8.7" sekali secara lokal untuk generate jar ini, lalu commit.
+  exit /b 1
+)
+"%JAVA_HOME%\bin\java.exe" -cp "%CLASSPATH%" org.gradle.wrapper.GradleWrapperMain %*
